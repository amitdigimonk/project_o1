<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="com.tossstudio.wallpaperengine">

  <application>

    <!--
      HtmlWallpaperService — universal WebView-based HTML5/Canvas live wallpaper.
      All wallpaper content is delivered as .zip files containing index.html and
      loaded over-the-air. The active file:// path is stored in SharedPreferences
      "HtmlWallpaperPrefs" by WallpaperEngineModule.saveHtmlWallpaperPath().
    -->
    <service
        android:name=".HtmlWallpaperService"
        android:label="HTML5 Wallpaper"
        android:permission="android.permission.BIND_WALLPAPER"
        android:exported="true">
        <intent-filter>
            <action android:name="android.service.wallpaper.WallpaperService" />
        </intent-filter>
        <meta-data
            android:name="android.service.wallpaper"
            android:resource="@xml/html_wallpaper" />
    </service>

  </application>

</manifest>
